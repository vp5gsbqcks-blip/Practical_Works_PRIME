        static int CountSymbols(string str) //Количество символов
        {
            int countSumbols = 0;
            foreach (char a in str)
            {
                if (a == 'А' || a == 'а' || a == 'A' || a == 'a') //Предусмотрел как ввод кириллицы, так и латиницы
                    countSumbols++;
            }
            MoreLetterA(countSumbols);
            return countSumbols;
        }
        static void MoreLetterA(int countSymbols) //Много букв А
        {
            if (countSymbols > 10)
                Console.WriteLine("\n В данной строке много букв \"А\"");
            return;
        }
        static int SumFiguresEvNumb(int[] arr_symbols) //Сумма чётных чисел
        {
            int sumFigures = 0;
            for (int i = 0; i < 10; i++)
            {
                if (arr_symbols[i] % 2 == 0)
                {
                    sumFigures += arr_symbols[i];
                }
            }
            return sumFigures;
        }
        static float SumTwoFigures(float[] num) //Сумма двух вещ.чисел
        {
            float sum_Two = 0;
            sum_Two = num[0] + num[1];
            return sum_Two;
        }
        static float DifferenceTwoFigures(float[] num) //Разность двух вещ.чисел
        {
            float dif_Two = 0;
            for (int i = 0; i < 2; i++)
                dif_Two = num[1] - num[0];
            return dif_Two;
        }
        static float MultiplicationTwoFigures(float[] num) //Произведение двух вещ.чисел
        {
            float mult_Two = 0;
            mult_Two = num[0] * num[1];
            return mult_Two;
        }
        static float DivisionTwoFigures(float[] num) //Частное двух вещ.чисел
        {
            float div_Two = 0;
            if (num[0] != 0 || num[1] != 0)
                div_Two = num[0] / num[1];
            else if (num[0] == 0 || num[1] == 0)
                Console.WriteLine("Ошибка! Деление на ноль!");
            else
                Console.WriteLine("Ошибка!");
            return div_Two;
        }
        static int FeelArray(int[] array) //Вывод массива с поиском числа 5
        {
            int a = 0;
            for (int i = 0; i < 10; i++)
