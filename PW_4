            }
            if (a == 0)
                Console.WriteLine("\nВ массиве не было встречено число 5.\n");
            return a;
        }
        static string RepetitionsOfTheSymbol(string str_1, char ch) //Поиск символа в строке
        {
            int count = 0;
            foreach (char с in str_1)
                if (с == ch)
                    count++;
            if (count == 0) Console.WriteLine($"\nДанного символа: {ch} в строке нет.");
            return count.ToString();
