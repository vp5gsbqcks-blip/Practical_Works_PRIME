            return sin_p;
        }        
        static float CalculatingTheCosinePrime(float a, float b, float c)
        {
            float cos_s;
            double cos_p = (Math.Pow(b, 2) + Math.Pow(c, 2) - Math.Pow(a, 2)) / (2 * b * c);
            cos_s = Convert.ToSingle(cos_p);
