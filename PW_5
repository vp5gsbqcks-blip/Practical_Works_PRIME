        static float CalculateCurrent(string U, string R) //Расчёт силы тока
        {
            float current;
            if (!float.TryParse(U, out float Uv))
            {
                Console.WriteLine("Ошибка #103. Значение напряжения должно быть числом.");
                return 0;
            }
            if (Uv > 1e15)
            {
                Console.WriteLine("Ошибка #104. Слишком большое число.");
                return 0;
            }
            if (!float.TryParse(R, out float Re))
            {
                Console.WriteLine("Ошибка #105. Значение сопротивления должно являться числом.");
                return 0;
            }
            if (Re > 1e15)
            {
                Console.WriteLine("Ошибка #106. Слишком большое число.");
                return 0;
            }
            if (Re <= 0)
            {
                Console.WriteLine("Ошибка #107. Значение сопротивления должно быть больше нуля.");
                return 0;
            }
            current = Uv / Re;
            return current;
        }
