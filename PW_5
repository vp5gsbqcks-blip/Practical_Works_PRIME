        static float CalculationOfCentripetalAcceleration(double rad, string t) //Расчёт центростремительного ускорения
        {
            double ac;
            float a;
            try
            {
                if (Convert.ToDouble(t) == 0)
                {
                    Console.WriteLine("Ошибка #302. Попытка деления на ноль.");
                    return 0;
                }
                ac = 4 * Math.Pow(3.14f, 2) * rad / Math.Pow(Convert.ToDouble(t), 2);
                a = Convert.ToSingle(ac);
            }
            catch
            {
                Console.WriteLine("Ошибка #304. Неизвестная ошибка.");
                return 0;
            }
            return a;
        }
        static float CheckingTheTriangle(float a, float b, float c) //Проверка возможности образования треугольника
        {
            if (a + b > c & a + c > b & b + c > a)
            {
                Console.WriteLine("Стороны могут образовать треугольник.");
                return 0;
            }
            else
            {
                Console.WriteLine("Ошибка #400. Стороны не могут образовать треугольник.");
                return 1;
            }
        }
        static float СheckingTheStraightnessOfATriangle(float a, float b, float c) //Проверка треугольника на прямость
        {
            double a_1 = 0, b_1 = 0, c_1 = 0, a_2 = 0, b_2 = 0, c_2 = 0;
            a_1 = Math.Pow(a, 2);
            b_1 = Math.Pow(b, 2);
            c_1 = Math.Pow(c, 2);
            a_2 = b_1 + c_1;
            b_2 = a_1 + c_1;
            c_2 = a_1 + b_1;
            if (c_2 == c_1)
            {
                if (b_2 == b_1)
                {
                    if (a_2 == a_1)
                        Console.WriteLine("Треугольник прямоугольный.");
                }
            }
            else
                return 1;
            return 0;
        }
        static float CalculatingTheSine(float a, float b, float c) //Вычисление синуса
        {
