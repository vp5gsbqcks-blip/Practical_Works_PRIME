        static float CircumferenceLength(in string r) //Длина окружности
        {
            float c = 0;
            if (!float.TryParse(r, out c))
            {
                Console.Clear();
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("Ошибка #100. Неверный ввод данных!");
                Console.ResetColor();
                return 0;
            }
            if (Convert.ToSingle(r) == 0)
            {
                Console.Clear();
                Console.ForegroundColor = ConsoleColor.Cyan;
                Console.WriteLine("\nЗначение равно нулю, так как ведённые данные: 0");
                Console.ResetColor();
                return 0;
            }
            if (Convert.ToSingle(r) < 0)
            {
                Console.Clear();
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("\nОшибка #101. Значение меньше нуля!");
                Console.ResetColor();
                return 0;
            }
            if (Convert.ToSingle(r) > 1e15)
            {
                Console.Clear();
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("\nОшибка #102. Слишком большое введённое значение.");
                Console.ResetColor();
                return 0;
            }
            c = 2 * Convert.ToSingle(Math.PI) * Convert.ToSingle(r);
            if (c == '?')
            {
                Console.Clear();
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("\nОшибка #103. Ошибка формата");
                Console.ResetColor();
                return 0;
            }
            if (Convert.ToSingle(c) > 1e15)
            {
                Console.Clear();
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("\nОшибка #104. Ответ имеет слишком большое значение.");
                Console.ResetColor();
                return 0;
            }
            return c;
        }
        static float Perimeter(params float[] figure) //Нахождение периметра фигуры
        {
            float P = 0;
            for (int i = 0; i < figure.Length; i++)
            {
                Console.Clear();
                if (figure[i] < 0)
                {
                    Console.ForegroundColor = ConsoleColor.Red;
                    Console.WriteLine("Ошибка #211. Значение стороны фигуры не должно быть меньше нуля!");
                    Console.ResetColor();
                    return 0;
                }
            }
            P = 2 * (figure[0] + figure[1]);
            return P;
        }       
        static string BinaryNumber(in int number) //Перевод в двоичку
        {
            if (number == 0) return "0";
            if (number == 1) return "1";
            return BinaryNumber(number / 2) + (number % 2).ToString();
        } 
        static bool QuantityNumberFive(params int[] numbers) //Количество цифер 5
        {
            int quan = 0;
            for (int i = 0; i < numbers.Length; i++)
            {
                if (numbers[i] == 5)
                    quan++;
            }
            if (quan > 0)
            {
                Console.WriteLine(quan);
                return true;
            }
            return false;
        }        
        static bool OccurrenceOfANumber(int[] symbols, out int iter) //Количество вхождений
        {
            iter = 0;
