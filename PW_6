            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine("Ошибка #500. Попытка деления на ноль!");
                Console.ResetColor();
                return false;                
            }
            do
            {
                quantity -= symbols[1];
                if (quantity >= 0)
                    iter++;
            }
            while (quantity >= 0);
            Console.Write($"Количество вхождений: ");
            Console.ForegroundColor = ConsoleColor.Green;
            Console.WriteLine(iter);
            Console.ResetColor();
            return true;
