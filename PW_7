using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ПР_7
{
    public class PostalDelivery
    {
        private int index;
        private string city;
        private string street;
        private int house;
        private int body;
        private int flat;
        private string message;
        public PostalDelivery(int newIndex, string newCity, string newStreet,
            int newHouse, int newBody, int newFlat, string newMessage)
        {
            index = newIndex;
            city = newCity;
            street = newStreet;
            house = newHouse;
            body = newBody;
            flat = newFlat;
            message = newMessage;
        }
        public PostalDelivery()
        {
            index = 0;
            city = "Не задан.";
            street = "Не задана.";
            house = 0;
            body = 0;
            flat = 0;
            message = "Пустое сообщение.";
        }
        public string Letter()
        {
            string adress = $"Адрес получателя: {city}, {street},{house}/{body}-{flat}. (Индекс: {index})\nСообщение: {message}";
            return adress;
        }
    }
}
