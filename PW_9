using System;

namespace ПР_9
{
    internal class Empire
    {
        public static int population;
        public static float square;

        public Empire()
        {
            population = 300000;
            square = 900000;
            Console.WriteLine("Не задано.");
        }
        public Empire(int newPopulation, float newSquare)
        {
            population = newPopulation;
            square = newSquare;
        }
        public static string EmpireAnalize(State state1)
        {
            if (state1.population >= population && state1.square >= square)
                return "\nЭто государство - империя: " + state1;
            else
                return "Государство " + state1 + "не империя";
        }
    }
}



using System.Collections.Generic;

namespace ПР_9
{
    internal class State
    {
        public string title;
        public int population;
        public float square;
        public State()
        {
            title = "Не задано";
            population = 0;
            square = 0;
        }
        public State(string newTitle, int newPopulation, float newSquare)
        {
            title = newTitle;
            population = newPopulation;
            square = newSquare;
        }
        List<State> objects = new List<State> ();
        public static State operator +(State state1, State state2)
        {
            State result = new State();
            result.title = state1.title + "+" + state2.title;
            result.population = state1.population + state2.population;
            result.square = state1.square + state2.square;
            return result;
        }
        public static bool operator <(State state1, State state2)
        {
            State result1 = new State();
            State result2 = new State();
            if (state1.population != state2.population)
            {
                return state1.population < result2.population;
            }
            else
                return state1.square < state2.square;
        }
        public static bool operator >(State state1, State state2)
        {
            if (state1.population != state2.population)
                return state1.population > state2.population;
            else
                return state1.square > state2.square;
        }
        public static bool operator <=(State state1, State state2)
        {
            return !(state1 > state2);
        }

        public static bool operator >=(State state1, State state2)
        {
            return !(state1 < state2);
        }
        public override string ToString()
        {
            return $"\nНазвание: {title}, Население: {population}, Площадь: {square}";
        }
    }
}
